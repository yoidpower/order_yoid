# ── YOID Power — SMTP Configuration ──────────────────────────
# Copy this file to .env and fill in your real credentials.
# The .env file is gitignored and never committed to GitHub.

# SMTP server hostname (e.g. mail.yoidpower.com or smtp.gmail.com)
SMTP_HOST=mail.yoidpower.com

# SMTP port: 587 for STARTTLS (recommended) / 465 for SSL
SMTP_PORT=587

# Encryption: tls (for port 587) or ssl (for port 465)
SMTP_SECURE=tls

# SMTP login credentials
SMTP_USER=noreply@yoidpower.com
SMTP_PASS=your_password_here

# Where form submissions are sent
MAIL_TO=orders@yoidpower.com

# From name and address shown in the email
MAIL_FROM=noreply@yoidpower.com
MAIL_FROM_NAME=YOID Power Website
