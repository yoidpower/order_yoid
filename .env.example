# ── YOID Power — SMTP Configuration ──────────────────────────
# Copy this file to .env and fill in your real credentials.
# The .env file is gitignored and never committed to GitHub.

# ── Option A: Use the server's own mailserver container ───────
# (Recommended — no external account needed)
# The mailserver container is on mailserver_mailnet network.
# Use the server's public hostname or IP since order_yoid is on
# yoidpower_proxy-tier and cannot reach mailserver directly.
SMTP_HOST=mail.yoidpower.com
SMTP_PORT=587
SMTP_SECURE=tls

# ── Option B: Gmail SMTP relay ────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=tls

# SMTP login credentials
SMTP_USER=noreply@yoidpower.com
SMTP_PASS=your_password_here

# Where form submissions are sent (fixed — do not change)
MAIL_TO=orders@yoidpower.com

# From name and address shown in the email
MAIL_FROM=noreply@yoidpower.com
MAIL_FROM_NAME=YOID Power Website
